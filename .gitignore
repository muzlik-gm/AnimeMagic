# --- Maven build artifacts ---
target/
*.jar
*.war
*.ear

# --- IDE files ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*~

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Runtime / generated files ---
# Plugin data folder (generated when the plugin runs on a server)
plugins/
server.log
logs/

# --- Resource pack build artifacts (keep the source PNGs but ignore the zipped output) ---
resource_pack/build/
resource_pack/assets/anime_magic/textures/item/*.png
!resource_pack/assets/anime_magic/textures/item/.gitkeep

# Note: textures are regenerated by scripts/generate_resource_pack.py —
# we don't commit the PNGs, only the generator script. Run the script
# after cloning to regenerate the textures locally.

# --- JDK / Maven downloads (if you put them in tools/) ---
tools/
*.tar.gz
*.zip

# --- Don't commit large binaries ---
*.mp4
*.mov
*.bak
