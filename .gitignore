# --- Maven build artifacts ---
target/
*.jar
*.war
*.ear

# --- IDE files ---
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*~

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Runtime / generated files ---
# Plugin data folder (generated when the plugin runs on a server)
plugins/
server.log
logs/

# --- Resource pack build artifacts (keep the source PNGs but ignore the zipped output) ---
resource_pack/build/

# Note: PNG textures in resource_pack/assets/anime_magic/textures/ ARE committed
# so they show up immediately when someone clones the repo. To regenerate them
# (e.g. after editing the Python generator), run: python3 scripts/generate_resource_pack.py

# --- JDK / Maven downloads (if you put them in tools/) ---
tools/
*.tar.gz

# --- Don't commit large binaries ---
*.mp4
*.mov
*.bak
